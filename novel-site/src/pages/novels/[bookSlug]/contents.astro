---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getBook, getChapters, getBooks } from "@/lib/chapters";
import { sitePath } from "@/lib/site";

export async function getStaticPaths() {
  const books = await getBooks();
  return books.map((book) => ({ params: { bookSlug: book.slug } }));
}

const { bookSlug } = Astro.params;
const book = await getBook(bookSlug);
const chapters = await getChapters(book.slug);
const first = chapters.at(0);
---

<BaseLayout title={`목차 | ${book.title}`}>
  <main class="contents-page">
    <header class="contents-hero">
      <a class="home-link home-link--dark" href={sitePath(`/novels/${book.slug}/`)}>작품 홈</a>
      <p class="section-label">Volume 01</p>
      <h1>목차</h1>
      <p>{book.title}</p>
      {first && <a class="button button--primary contents-hero__button" href={sitePath(`/novels/${book.slug}/chapters/${first.slug}/`)}>처음부터 읽기</a>}
    </header>

    <section class="site-shell chapter-list" aria-label="회차 목록">
      <div class="chapters chapters--single">
        {chapters.map((chapter) => (
          <a class="chapter-card chapter-card--row" href={sitePath(`/novels/${book.slug}/chapters/${chapter.slug}/`)}>
            <span>{String(chapter.number).padStart(2, "0")}</span>
            <div>
              <h2>{chapter.title}</h2>
              <p>{chapter.excerpt}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
