---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Comments from "@/components/Comments.astro";
import { getBook, getBooks, getChapters } from "@/lib/chapters";
import { sitePath } from "@/lib/site";

export async function getStaticPaths() {
  const books = await getBooks();
  const paths = [];
  for (const book of books) {
    const activeVolume = book.active_volume;
    if (activeVolume) {
      const chapters = await getChapters(book.slug, activeVolume);
      paths.push(...chapters.map((chapter) => ({ params: { bookSlug: book.slug, slug: chapter.slug } })));
    }
  }
  return paths;
}

const { bookSlug, slug } = Astro.params;
const book = await getBook(bookSlug);
const activeVolume = book.active_volume;
return Astro.redirect(sitePath(activeVolume ? `/novels/${book.slug}/volumes/${activeVolume}/chapters/${slug}/` : `/novels/${book.slug}/`));
---
