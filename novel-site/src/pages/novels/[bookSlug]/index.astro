---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getBook, getChapters, getBooks } from "@/lib/chapters";
import { sitePath } from "@/lib/site";

export async function getStaticPaths() {
  const books = await getBooks();
  return books.map((book) => ({ params: { bookSlug: book.slug } }));
}

const { bookSlug } = Astro.params;
const book = await getBook(bookSlug);
const chapters = await getChapters(book.slug);
const first = chapters.at(0);
---

<BaseLayout title={`${book.title} | 작품 홈`} description={book.description}>
  <main>
    <section class="hero hero--book-home">
      {book.cover ? <img class="hero__image" src={sitePath(book.cover)} alt="" /> : <div class="hero__image hero__image--empty"></div>}
      <div class="hero__shade"></div>
      <div class="hero__content">
        <a class="home-link home-link--hero" href={sitePath("/")}>작품 서재</a>
        <p class="eyebrow">{book.author ?? "BLACKINK"} · {book.genre.replaceAll("_", " ")}</p>
        <h1>{book.title}</h1>
        <div class="hero__copy">
          {book.synopsis?.map((paragraph) => <p>{paragraph}</p>) ?? <p>{book.description ?? "이야기의 첫 장을 펼쳐 보세요."}</p>}
        </div>
        <div class="hero__actions">
          <a class="button button--primary" href={sitePath(first ? `/novels/${book.slug}/chapters/${first.slug}/` : `/novels/${book.slug}/`)}>처음부터 읽기</a>
        </div>
      </div>
    </section>

    <section class="site-shell chapter-list" aria-labelledby="chapter-list-title">
      <div class="chapter-list__header">
        <div>
          <p class="section-label">Volume 01</p>
          <h2 id="chapter-list-title">목차</h2>
        </div>
        <div class="chapter-list__tools">
          <span>{chapters.length}회</span>
          <div class="chapter-sort" role="group" aria-label="회차 정렬">
            <button class="chapter-sort__button is-active" type="button" data-sort="ascending" aria-pressed="true">처음부터</button>
            <button class="chapter-sort__button" type="button" data-sort="descending" aria-pressed="false">최신화순</button>
          </div>
        </div>
      </div>
      <div class="chapters chapters--single" id="chapter-list">
        {chapters.map((chapter) => (
          <a class="chapter-card chapter-card--row" data-chapter-number={chapter.number} href={sitePath(`/novels/${book.slug}/chapters/${chapter.slug}/`)}>
            <span>{String(chapter.number).padStart(2, "0")}</span>
            <div>
              <h2>{chapter.title}</h2>
              <p>{chapter.excerpt}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const chapterList = document.querySelector<HTMLElement>("#chapter-list");
  const sortButtons = document.querySelectorAll<HTMLButtonElement>("[data-sort]");

  sortButtons.forEach((button) => {
    button.addEventListener("click", () => {
      if (!chapterList) return;

      const cards = Array.from(chapterList.querySelectorAll<HTMLElement>("[data-chapter-number]"));
      const descending = button.dataset.sort === "descending";
      cards
        .sort((a, b) => {
          const difference = Number(a.dataset.chapterNumber) - Number(b.dataset.chapterNumber);
          return descending ? -difference : difference;
        })
        .forEach((card) => chapterList.appendChild(card));

      sortButtons.forEach((item) => {
        const active = item === button;
        item.classList.toggle("is-active", active);
        item.setAttribute("aria-pressed", String(active));
      });
    });
  });
</script>
