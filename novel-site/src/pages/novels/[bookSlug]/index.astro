---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getBook, getChapters, getBooks, getVolumes } from "@/lib/chapters";
import { sitePath } from "@/lib/site";

export async function getStaticPaths() {
  const books = await getBooks();
  return books.map((book) => ({ params: { bookSlug: book.slug } }));
}

const { bookSlug } = Astro.params;
const book = await getBook(bookSlug);
const volumes = await getVolumes(book.slug);
const firstVolume = volumes.at(0);
const firstChapters = firstVolume ? await getChapters(book.slug, firstVolume.slug) : await getChapters(book.slug);
const first = firstChapters.at(0);
---

<BaseLayout title={`${book.title} | 작품 홈`} description={book.description}>
  <main>
    <section class="hero hero--book-home">
      {book.cover ? <img class="hero__image" src={sitePath(book.cover)} alt="" /> : <div class="hero__image hero__image--empty"></div>}
      <div class="hero__shade"></div>
      <div class="hero__content">
        <a class="home-link home-link--hero" href={sitePath("/")}>작품 서재</a>
        <p class="eyebrow">{book.author ?? "BLACKINK"} · {book.genre.replaceAll("_", " ")}</p>
        <h1>{book.title}</h1>
        <div class="hero__copy">
          {book.synopsis?.map((paragraph) => <p>{paragraph}</p>) ?? <p>{book.description ?? "이야기의 첫 장을 펼쳐 보세요."}</p>}
        </div>
        <div class="hero__actions">
          <a class="button button--primary" href={sitePath(first && firstVolume ? `/novels/${book.slug}/volumes/${firstVolume.slug}/chapters/${first.slug}/` : `/novels/${book.slug}/`)}>처음부터 읽기</a>
        </div>
      </div>
    </section>

    <section class="site-shell chapter-list" aria-labelledby="chapter-list-title">
      <div class="chapter-list__header">
        <div>
          <p class="section-label">Volumes</p>
          <h2 id="chapter-list-title">권 목록</h2>
        </div>
      </div>
      <div class="chapters chapters--single">
        {volumes.map((volume) => (
          <a class="chapter-card chapter-card--row" href={sitePath(`/novels/${book.slug}/volumes/${volume.slug}/`)}>
            <span>{volume.label.replace("VOLUME ", "")}</span>
            <div>
              <h2>{volume.title}</h2>
              <p>{volume.description ?? `${volume.chapter_count ?? 0}화`}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
